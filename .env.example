# Cambium environment variables
# Copy to .env and fill in real values before running.

# Postgres connection string — cambium schema (users, refresh_tokens)
# Note: use plain postgresql:// (pgx driver), not postgresql+psycopg2://
DATABASE_URL=postgresql://postgres:dev@localhost:5432/postgres

# JWT signing secret — HS256, minimum 32 bytes
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-bytes!!

# AES-256-GCM master key for encrypting provider API keys — must be exactly 32 bytes
# Generate with: openssl rand -hex 16   (gives 32 hex chars = 32 bytes)
CAMBIUM_ENCRYPTION_KEY=change-me-to-exactly-32-bytes!!x

# Base URL of Rhizome's internal FastAPI server
# Run Rhizome with: python server.py  (default port 8001)
RHIZOME_INTERNAL_URL=http://localhost:8001

# HTTP listen port for Cambium (default: 8080)
PORT=8080

# Directory containing the built Verdant Pages frontend (npm run build output)
# Served for all non-API routes; unknown paths fall back to index.html for
# client-side routing. (default: ./dist)
STATIC_DIR=./dist
